digraph agent_user_flow {
  rankdir=LR;
  labelloc="t";
  label="Agent User Flow";

  node [shape=ellipse];

  none;
  saved;
  starting;
  ready;
  failed;

  none -> saved [label="config"];
  saved -> saved [label="config"];
  ready -> saved [label="config"];
  failed -> saved [label="config"];

  saved -> starting [label="apply"];
  ready -> starting [label="apply"];
  failed -> starting [label="apply"];

  starting -> ready [label="system: pod ready"];
  starting -> failed [label="system: scheduling/mount/bootstrap/runtime failure"];

  ready -> ready [label="exec"];

  none -> none [style=dashed, label="status"];
  saved -> saved [style=dashed, label="status"];
  starting -> starting [style=dashed, label="status"];
  ready -> ready [style=dashed, label="status"];
  failed -> failed [style=dashed, label="status"];

  saved -> none [label="delete"];
  starting -> none [label="delete"];
  ready -> none [label="delete"];
  failed -> none [label="delete"];
}
